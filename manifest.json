{
    "short_name": "GelCifras",
    "name": "GelCifras - Gerenciador de Cifras",
    "version": "3.7",
    "icons": [{
        "src": "apple-touch-icon.png",
        "type": "image/png",
        "sizes": "512x512"
    }],
    "start_url": "/index.html",
    "background_color": "#0f172a",
    "theme_color": "#1d4ed8",
    "display": "standalone",
    "share_target": {
        "action": "/_share-target",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "title": "title",
            "text": "text",
            "files": [{
                "name": "file",
                "accept": ["text/plain", ".txt"]
            }]
        }
    }
}